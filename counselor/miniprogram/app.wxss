.announcement-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin: 12rpx 24rpx;
  background: linear-gradient(135deg, #fff8e1, #fff3cd);
  border-radius: 12rpx;
  border-left: 6rpx solid #ff9800;
}
.announcement-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.announcement-text {
  flex: 1;
  font-size: 26rpx;
  color: #e65100;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

page {
  background-color: #F8F7FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

view, text {
  box-sizing: border-box;
}

image {
  display: block;
}

.page-container {
  padding-bottom: 120rpx;
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 999;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}
