page {
  background-color: #F8F7FC;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.record-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.record-avatar .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2438;
  display: block;
  margin-bottom: 8rpx;
}

.record-meta {
  display: flex;
  align-items: center;
}

.service-tag {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #6B6380;
}

.record-status {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
}

.record-status.completed {
  background: #d1fae5;
}

.record-status.completed text {
  color: #3AB88A;
  font-size: 24rpx;
}

.record-status.draft {
  background: #FFF7E6;
}

.record-status.draft text {
  color: #F59E0B;
  font-size: 24rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2438;
  margin-bottom: 16rpx;
}

.section-content {
  font-size: 28rpx;
  color: #2D2438;
  line-height: 1.8;
}

.edit-textarea {
  width: 100%;
  height: 200rpx;
  background: #F5F2FC;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.info-grid {
  display: flex;
  gap: 40rpx;
}

.info-item {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #A099B0;
  display: block;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #2D2438;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.action-btn.primary text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background: #F5F2FC;
}

.action-btn.secondary text {
  color: #6B6380;
  font-size: 30rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #F5F2FC;
  border-top: 6rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #A099B0;
}
