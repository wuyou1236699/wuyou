page {
  background-color: #F8F7FC;
  min-height: 100vh;
}

.container {
  padding: 0 20rpx 120rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 40rpx 24rpx;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 20rpx;
}

.profile-avatar {
  position: relative;
  margin-right: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.edit-btn {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-btn text {
  font-size: 22rpx;
  color: #7C6FF7;
  font-weight: 500;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.profile-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 8rpx;
}

.profile-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.meta-dot {
  margin: 0 12rpx;
  color: rgba(255, 255, 255, 0.4);
}

.profile-rating {
  display: flex;
  align-items: center;
}

.rating-star {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.rating-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2D2438;
  display: block;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #A099B0;
}

.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F2FC;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #2D2438;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
}

.contact-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-label {
  font-size: 26rpx;
  color: #6B6380;
  width: 120rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #2D2438;
}

.logout-btn {
  background: #fff;
  border-radius: 40rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.logout-btn text {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #F5F2FC;
  border-top: 6rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #A099B0;
}
