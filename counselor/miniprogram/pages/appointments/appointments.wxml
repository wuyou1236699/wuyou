<view class="container" wx:if="{{!loading}}">
  <view class="status-bar">
    <view class="status-indicator {{isOnline ? 'online' : 'offline'}}">
      <view class="status-dot"></view>
      <text class="status-text">{{isOnline ? '在线' : '离线'}}</text>
    </view>
  </view>

  <view class="tab-header">
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      <text class="tab-text">待处理({{pendingAppointments.length}})</text>
      <view class="tab-line {{activeTab === 'pending' ? 'active' : ''}}"></view>
    </view>
    <view class="tab-item {{activeTab === 'confirmed' ? 'active' : ''}}" bindtap="switchTab" data-tab="confirmed">
      <text class="tab-text">已确认({{confirmedAppointments.length}})</text>
      <view class="tab-line {{activeTab === 'confirmed' ? 'active' : ''}}"></view>
    </view>
    <view class="tab-item {{activeTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">
      <text class="tab-text">历史</text>
      <view class="tab-line {{activeTab === 'history' ? 'active' : ''}}"></view>
    </view>
  </view>

  <view class="tab-content">
    <view class="appointment-list" wx:if="{{activeTab === 'pending'}}">
      <view class="appointment-card" wx:for="{{pendingAppointments}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-header">
          <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="header-info">
            <text class="user-name">{{item.userName}}</text>
            <text class="service-type {{item.serviceType === 1 ? 'phone' : (item.serviceType === 2 ? 'online' : 'clinic')}}">
              {{item.serviceTypeText}}
            </text>
          </view>
          <view class="status-badge pending">待确认</view>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📅</text>
            <text class="info-text">{{item.dateText}} {{item.timeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.problem}}">
            <text class="info-icon">💬</text>
            <text class="info-text">{{item.problem}}</text>
          </view>
        </view>
        <view class="card-footer">
          <button class="btn-primary" size="mini" bindtap="goToDetail" data-id="{{item.id}}">查看详情</button>
        </view>
      </view>

      <view class="empty-state" wx:if="{{pendingAppointments.length === 0}}">
        <text class="empty-icon">📅</text>
        <text class="empty-text">暂无待处理预约</text>
      </view>
    </view>

    <view class="appointment-list" wx:if="{{activeTab === 'confirmed'}}">
      <view class="appointment-card" wx:for="{{confirmedAppointments}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-header">
          <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="header-info">
            <text class="user-name">{{item.userName}}</text>
            <text class="service-type {{item.serviceType === 1 ? 'phone' : (item.serviceType === 2 ? 'online' : 'clinic')}}">
              {{item.serviceTypeText}}
            </text>
          </view>
          <view class="status-badge confirmed">已确认</view>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📅</text>
            <text class="info-text">{{item.dateText}} {{item.timeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.problem}}">
            <text class="info-icon">💬</text>
            <text class="info-text">{{item.problem}}</text>
          </view>
        </view>
        <view class="card-footer">
          <button class="btn-start" size="mini" bindtap="goOnline" data-item="{{item}}" wx:if="{{item.serviceType !== 3}}">开始咨询</button>
          <view class="card-footer" wx:else>
            <text class="clinic-tip">门诊预约，请等待用户到诊</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{confirmedAppointments.length === 0}}">
        <text class="empty-icon">📅</text>
        <text class="empty-text">暂无已确认预约</text>
      </view>
    </view>

    <view class="appointment-list" wx:if="{{activeTab === 'history'}}">
      <view class="appointment-card completed" wx:for="{{historyAppointments}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-header">
          <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="header-info">
            <text class="user-name">{{item.userName}}</text>
            <text class="service-type {{item.serviceType === 1 ? 'phone' : (item.serviceType === 2 ? 'online' : 'clinic')}}">
              {{item.serviceTypeText}}
            </text>
          </view>
          <view class="status-badge completed">{{item.status === 2 ? '已完成' : '已取消'}}</view>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📅</text>
            <text class="info-text">{{item.dateText}} {{item.timeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.problem}}">
            <text class="info-icon">💬</text>
            <text class="info-text">{{item.problem}}</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{historyAppointments.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无历史记录</text>
      </view>
    </view>
  </view>
</view>

<view class="loading-state" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>