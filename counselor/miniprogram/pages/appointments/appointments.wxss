page {
  background: linear-gradient(180deg, #F0EDFF 0%, #F8F7FC 100%);
  min-height: 100vh;
}

.container {
  padding: 0 0 120rpx;
}

.status-bar {
  padding: 20rpx 30rpx;
  background: #fff;
  display: flex;
  justify-content: flex-end;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  background: #F5F2FC;
}

.status-indicator.online {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.status-indicator.offline {
  background: linear-gradient(135deg, #fff1f0 0%, #fff5f5 100%);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #A099B0;
  animation: pulse 2s infinite;
}

.status-indicator.online .status-dot {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
  box-shadow: 0 0 10rpx rgba(78, 203, 156, 0.4);
}

.status-indicator.offline .status-dot {
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.4);
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.1); }
}

.status-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B6380;
}

.status-indicator.online .status-text {
  color: #3AB88A;
}

.status-indicator.offline .status-text {
  color: #E55A5A;
}

.tab-header {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #6B6380;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #7C6FF7;
  font-weight: 600;
}

.tab-line {
  width: 0;
  height: 6rpx;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  border-radius: 3rpx;
  margin-top: 12rpx;
  transition: width 0.3s ease;
}

.tab-item.active .tab-line {
  width: 60rpx;
}

.tab-content {
  padding: 0 24rpx;
}

.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.appointment-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.appointment-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #7C6FF7 0%, #6558D3 100%);
}

.appointment-card.completed::before {
  background: linear-gradient(90deg, #4ECB9C 0%, #3AB88A 100%);
}

.appointment-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(124, 111, 247, 0.3);
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D2438;
}

.service-type {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  align-self: flex-start;
  font-weight: 500;
}

.service-type.phone {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.service-type.online {
  background: linear-gradient(135deg, #6558D3 0%, #7C6FF7 100%);
}

.service-type.clinic {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-badge.pending {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
}

.status-badge.confirmed {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #3AB88A;
}

.status-badge.completed {
  background: linear-gradient(135deg, #F0EDFF 0%, #E2DCFF 100%);
  color: #7C6FF7;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  opacity: 0.8;
}

.info-text {
  font-size: 28rpx;
  color: #6B6380;
  flex: 1;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
}

.btn-primary,
.btn-start,
.btn-record {
  padding: 18rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.btn-primary {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: #fff;
}

.btn-start {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
  color: #fff;
}

.btn-record {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: #fff;
}

.btn-primary:active,
.btn-start:active,
.btn-record:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #A099B0;
  font-weight: 500;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #F5F2FC;
  border-top: 8rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #A099B0;
  font-weight: 500;
}

.clinic-tip {
  font-size: 24rpx;
  color: #A099B0;
  padding: 18rpx 0;
}
