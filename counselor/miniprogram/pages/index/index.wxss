.container {
  background: linear-gradient(180deg, #F0EDFF 0%, #F8F7FC 100%);
  min-height: 100vh;
  padding: 0;
}

.status-card {
  position: relative;
  margin: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 247, 0.15);
}

.status-card.online {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
}

.status-card.offline {
  background: linear-gradient(135deg, #A099B0 0%, #6B6380 100%);
}

.status-bg {
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transform: translate(80rpx, -80rpx);
}

.status-content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
}

.status-left {
  display: flex;
  align-items: center;
}

.status-indicator {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
}

.pulse-ring {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  opacity: 0;
}

.pulse-ring.active {
  animation: pulse-ring 2s infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

.status-dot-large {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.status-dot-large.online {
  background: #fff;
  box-shadow: 0 0 16rpx rgba(255, 255, 255, 0.8);
}

.status-dot-large.offline {
  background: #d1d5db;
}

.status-info {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.status-toggle-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.toggle-switch {
  width: 100rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 26rpx;
  position: relative;
  transition: all 0.3s ease;
}

.toggle-switch.active {
  background: rgba(255, 255, 255, 0.5);
}

.toggle-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 50%;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.toggle-switch.active .toggle-knob {
  left: 52rpx;
}

.toggle-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
}

.greeting-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D2438;
  display: block;
  margin-bottom: 8rpx;
}

.greeting-subtitle {
  font-size: 28rpx;
  color: #6B6380;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.stat-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.stat-icon-wrapper.blue {
  background: linear-gradient(135deg, #E8E2FF 0%, #D5CCFF 100%);
}

.stat-icon-wrapper.green {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.stat-icon-wrapper.purple {
  background: linear-gradient(135deg, #F0EDFF 0%, #E2DCFF 100%);
}

.stat-icon-wrapper.orange {
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
}

.stat-icon {
  font-size: 36rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D2438;
  display: block;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #A099B0;
}

.quick-actions {
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D2438;
  margin-bottom: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrapper.blue {
  background: linear-gradient(135deg, #E8E2FF 0%, #D5CCFF 100%);
}

.action-icon-wrapper.green {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.action-icon-wrapper.purple {
  background: linear-gradient(135deg, #F0EDFF 0%, #E2DCFF 100%);
}

.action-icon-wrapper.orange {
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
}

.action-icon {
  font-size: 44rpx;
}

.action-text {
  font-size: 26rpx;
  color: #2D2438;
  font-weight: 500;
}

.action-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  color: white;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}

.upcoming-section {
  padding: 0 20rpx;
  margin-bottom: 120rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.more-link {
  font-size: 26rpx;
  color: #7C6FF7;
}

.upcoming-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.upcoming-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.upcoming-avatar {
  position: relative;
  margin-right: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.service-tag {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.service-tag.blue {
  background: linear-gradient(135deg, #6558D3 0%, #7C6FF7 100%);
}

.service-tag.green {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
}

.service-tag.orange {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.upcoming-info {
  flex: 1;
}

.upcoming-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2438;
  display: block;
  margin-bottom: 8rpx;
}

.upcoming-service {
  font-size: 26rpx;
  color: #6B6380;
}

.upcoming-time {
  text-align: right;
  margin-right: 16rpx;
}

.time-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #7C6FF7;
  display: block;
  margin-bottom: 4rpx;
}

.date-text {
  font-size: 22rpx;
  color: #A099B0;
}

.upcoming-action {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
}

.action-btn {
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #A099B0;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #F0EDFF 0%, #F8F7FC 100%);
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e5e7eb;
  border-top: 6rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #A099B0;
}
