.container {
  min-height: 100vh;
  background: #F8F7FC;
  padding: 20rpx;
}

.detail-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  border-bottom: 1px solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D2438;
}

.info-section {
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6B6380;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #2D2438;
  text-align: right;
  margin-left: 20rpx;
}

.service-tag, .status-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.service-tag.phone {
  background: #FFF7E6;
  color: #D97706;
}

.service-tag.online {
  background: #E8E2FF;
  color: #7C6FF7;
}

.service-tag.clinic {
  background: #E6FAF2;
  color: #3AB88A;
}

.status-tag.pending {
  background: #FFF7E6;
  color: #D97706;
}

.status-tag.confirmed {
  background: #E8E2FF;
  color: #7C6FF7;
}

.status-tag.completed {
  background: #E6FAF2;
  color: #3AB88A;
}

.status-tag.cancelled {
  background: #FFEEEE;
  color: #FF6B6B;
}

.problem-text {
  flex: 1;
  text-align: left;
  color: #6B6380;
  line-height: 1.5;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary, .btn-start, .btn-complete, .btn-cancel {
  width: 100%;
  height: 88rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: white;
}

.btn-start {
  background: linear-gradient(135deg, #4ECB9C 0%, #3AB88A 100%);
  color: white;
}

.btn-complete {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: white;
}

.btn-cancel {
  background: white;
  color: #6B6380;
  border: 1px solid #ddd;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #A099B0;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F5F2FC;
  border-top-color: #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #A099B0;
}