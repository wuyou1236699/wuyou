page {
  background-color: #F8F7FC;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-avatar {
  margin: 0 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar.self {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.avatar.other {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.message-content {
  max-width: 70%;
}

.message-item.self .message-content {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-text {
  background: #fff;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #2D2438;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  word-break: break-word;
  align-self: flex-start;
}

.message-item.self .message-text {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: #fff;
  border-radius: 24rpx;
  align-self: auto;
}

.message-time {
  font-size: 22rpx;
  color: #A099B0;
  margin-top: 8rpx;
}

.message-item.self .message-time {
  text-align: right;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.input-field {
  flex: 1;
  height: 80rpx;
  background: #F5F2FC;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  margin-left: 20rpx;
}

.send-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.load-more-tip {
  text-align: center;
  padding: 16rpx;
  color: #8C8CA1;
  font-size: 24rpx;
}

.reply-notice {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFF9E6;
  color: #8B6914;
  font-size: 26rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
