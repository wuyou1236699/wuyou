page {
  background-color: #F8F7FC;
  min-height: 100vh;
}

.container {
  padding: 0 0 120rpx;
}

.online-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.message-stats {
  display: flex;
  align-items: center;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 28rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 2rpx;
}

.stat-divider-v {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

.stats {
  display: flex;
  align-items: center;
}

.stat-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  margin: 0 16rpx;
  color: rgba(255, 255, 255, 0.5);
}

.search-bar {
  padding: 20rpx;
  background: #fff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F2FC;
  border-radius: 40rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #A099B0;
  padding: 8rpx;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx 20rpx;
  border-bottom: 1rpx solid #F5F2FC;
}

.filter-tab {
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: #F5F2FC;
  font-size: 26rpx;
  color: #6B6380;
}

.filter-tab.active {
  background: #7C6FF7;
  color: #fff;
}

/* Condition filter bar */
.condition-bar {
  white-space: nowrap;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #F5F2FC;
}

.condition-item {
  display: inline-flex;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 32rpx;
  background: #F5F2FC;
  font-size: 24rpx;
  color: #6B6380;
}

.condition-item.active {
  background: #FFF0ED;
  color: #FF7E67;
  font-weight: 500;
}

.chat-list {
  padding: 20rpx;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chat-avatar {
  position: relative;
  margin-right: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.online-indicator {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.online-indicator.online {
  background: #22c55e;
}

.online-indicator.offline {
  background: #A099B0;
}

.chat-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chat-name-row {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.chat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2438;
  flex-shrink: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-tag {
  font-size: 22rpx;
  color: #7C6FF7;
  background: #F0EDFF;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.chat-tag.date {
  color: #6B6380;
  background: #F5F2FC;
}

.chat-tag.condition {
  color: #FF7E67;
  background: #FFF0ED;
}

.chat-time {
  font-size: 24rpx;
  color: #A099B0;
}

.chat-message {
  font-size: 26rpx;
  color: #6B6380;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-badge {
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  color: #fff;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #A099B0;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #F5F2FC;
  border-top: 6rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #A099B0;
}
