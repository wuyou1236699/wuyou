<view class="container">
  <scroll-view
    class="message-list"
    scroll-y
    scroll-top="{{scrollTop}}"
    bindscrolltoupper="loadMore"
  >
    <view class="load-more-tip" wx:if="{{hasMore}}">
      <text wx:if="{{!loadingMore}}" bindtap="loadMore">加载更早消息</text>
      <text wx:else>加载中...</text>
    </view>
    <view
      class="message-item {{item.sender === 'counselor' ? 'self' : 'other'}}"
      wx:for="{{messages}}"
      wx:key="id"
      bindlongpress="onDeleteMsg"
      data-index="{{index}}"
    >
      <view class="message-avatar">
        <view class="avatar {{item.sender === 'counselor' ? 'self' : 'other'}}"></view>
      </view>
      <view class="message-content">
        <view class="message-text">{{item.content}}</view>
        <text class="message-time">{{item.time}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar" wx:if="{{canReply}}">
    <input
      class="input-field"
      placeholder="输入消息..."
      value="{{inputMessage}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <view class="send-btn" bindtap="sendMessage">
      <text>发送</text>
    </view>
  </view>
  <view class="reply-notice" wx:if="{{!canReply}}">
    <text>{{replyNotice}}</text>
  </view>
</view>
