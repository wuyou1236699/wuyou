page {
  background-color: #F8F7FC;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.schedule-calendar {
  padding-bottom: 20rpx;
}

.calendar-header {
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2438;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.date-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F2FC;
}

.time-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-item {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #0369a1;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2438;
  display: block;
  margin-bottom: 12rpx;
}

.slot-count {
  font-size: 24rpx;
  color: #6B6380;
  margin-bottom: 12rpx;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.status-tag.published {
  background: #d1fae5;
}

.status-tag.published text {
  color: #3AB88A;
  font-size: 22rpx;
}

.status-tag.draft {
  background: #FFF7E6;
}

.status-tag.draft text {
  color: #F59E0B;
  font-size: 22rpx;
}

.slot-editor {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F2FC;
}

.editor-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2438;
}

.close-btn {
  font-size: 36rpx;
  color: #A099B0;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 16rpx;
}

.time-slot {
  padding: 20rpx 32rpx;
  background: #F5F2FC;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D2438;
}

.time-slot.selected {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
  color: #fff;
}

.editor-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-top: 1rpx solid #F5F2FC;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 32rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #7C6FF7 0%, #6558D3 100%);
}

.action-btn.primary text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background: #F5F2FC;
}

.action-btn.secondary text {
  color: #6B6380;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #A099B0;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #F5F2FC;
  border-top: 6rpx solid #7C6FF7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #A099B0;
}
