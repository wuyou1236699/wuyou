/**app.wxss**/
.announcement-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin: 12rpx 24rpx;
  background: linear-gradient(135deg, #FFF0ED, #FFE8E3);
  border-radius: 12rpx;
  border-left: 6rpx solid #FF7E67;
}
.announcement-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.announcement-text {
  flex: 1;
  font-size: 26rpx;
  color: #E06952;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 推荐方式区域 */
.recommend-section {
  margin: 16rpx 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}
.recommend-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.recommend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2C2C;
}
.recommend-hint {
  font-size: 22rpx;
  color: #B8A0A0;
}
.recommend-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.chip {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  background: #FFF5F2;
  font-size: 24rpx;
  color: #8C7373;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.chip.active {
  background: #FFF0ED;
  color: #FF7E67;
  border-color: #FF7E67;
}
.problem-picker {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.picker-label {
  font-size: 24rpx;
  color: #8C7373;
  margin-right: 10rpx;
}
.filter-picker {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #FFF5F2;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #3D2C2C;
}
.picker-arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #B8A0A0;
}
.recommend-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.apply-btn {
  flex: 1;
  padding: 14rpx;
  background: linear-gradient(135deg, #FF7E67, #E06952);
  color: #fff;
  border-radius: 48rpx;
  font-size: 26rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(255,126,103,0.25);
}
.reset-btn {
  flex: 1;
  padding: 14rpx;
  background: #FFF5F2;
  color: #8C7373;
  border-radius: 28rpx;
  font-size: 26rpx;
  text-align: center;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}
