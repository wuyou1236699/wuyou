.container {
  min-height: 100vh;
  background: #FDF8F5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  display: block;
}

.history-list {
  padding: 20rpx;
  margin-top: -40rpx;
}

.history-card {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.history-info {
  flex: 1;
}

.history-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3D2C2C;
  display: block;
}

.history-time {
  font-size: 24rpx;
  color: #B8A0A0;
  margin-top: 8rpx;
  display: block;
}

.history-result {
  text-align: right;
  margin-right: 20rpx;
}

.result-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #3D2C2C;
  display: block;
}

.result-level {
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 4rpx;
  display: block;
}

.history-arrow {
  width: 48rpx;
  height: 48rpx;
  background: #FDF8F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #B8A0A0;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #B8A0A0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8A0A0;
  margin-bottom: 30rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  border-radius: 30rpx;
  color: white;
  font-size: 28rpx;
  border: none;
}
