<view class="container" wx:if="!showResult">
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{(currentIndex + 1) / questions.length * 100}}%"></view>
  </view>

  <view class="question-header">
    <text class="question-progress">{{currentIndex + 1}} / {{questions.length}}</text>
    <text class="question-title">{{testTitle}}</text>
  </view>

  <view class="question-card" wx:if="!loading">
    <text class="question-text">{{questions[currentIndex].question}}</text>
    
    <view class="options-list">
      <view 
        wx:for="{{questions[currentIndex].options}}" 
        wx:key="id"
        class="option-item {{answers[questions[currentIndex].id] === item.id ? 'selected' : ''}}"
        bindtap="onOptionSelect"
        data-question-id="{{questions[currentIndex].id}}"
        data-option-id="{{item.id}}"
      >
        <text class="option-letter">{{item.id}}</text>
        <text class="option-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="question-nav">
    <view class="nav-dots">
      <view 
        wx:for="{{questions}}" 
        wx:key="id"
        class="nav-dot {{currentIndex === index ? 'active' : ''}} {{answers[item.id] ? 'answered' : ''}}"
        bindtap="goToQuestion"
        data-index="{{index}}"
      ></view>
    </view>
  </view>

  <view class="footer">
    <button 
      class="footer-btn secondary" 
      bindtap="prevQuestion"
      disabled="{{currentIndex === 0}}"
    >
      上一题
    </button>
    <button 
      class="footer-btn primary" 
      wx:if="{{currentIndex < questions.length - 1}}"
      bindtap="nextQuestion"
    >
      下一题
    </button>
    <button 
      class="footer-btn primary" 
      wx:else
      bindtap="submitTest"
    >
      提交测评
    </button>
  </view>
</view>

<view class="result-container" wx:if="{{showResult}}">
  <view class="result-card">
    <view class="result-header">
      <text class="result-title">测评结果</text>
      <text class="result-test">{{result.testTitle}}</text>
    </view>
    
    <view class="score-section">
      <view class="score-circle" style="background: linear-gradient(135deg, {{resultColor}}22 0%, {{resultColor}}44 100%);">
        <text class="score-value" style="color: {{resultColor}};">{{result.score}}</text>
        <text class="score-label">得分</text>
      </view>
    </view>
    
    <view class="level-section">
      <text class="level-label">评估等级</text>
      <text class="level-value" style="color: {{resultColor}};">{{result.level}}</text>
    </view>
    
    <view class="advice-section">
      <text class="advice-label">💡 建议</text>
      <text class="advice-text">{{result.advice}}</text>
    </view>
    
    <view class="result-footer">
      <button class="result-btn" bindtap="retakeTest">
        <text>重新测评</text>
      </button>
      <button class="result-btn secondary" bindtap="goBack">
        <text>返回列表</text>
      </button>
    </view>
  </view>
</view>
