<view class="container">
  <view class="page-title">我的评价</view>

  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>

  <block wx:elif="{{reviews.length === 0}}">
    <view class="empty">暂无评价记录</view>
  </block>

  <block wx:else>
    <view class="review-list">
      <view class="review-card" wx:for="{{reviews}}" wx:key="id" bindtap="goToCounselor" data-id="{{item.counselorId}}">
        <view class="review-header">
          <text class="counselor-name">{{item.counselorName || '咨询师'}}</text>
          <view class="stars">
            <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" wx:for-item="star"
                  class="star {{star <= item.rating ? 'filled' : 'empty'}}">★</text>
          </view>
        </view>
        <view class="review-content" wx:if="{{item.content}}">
          <text>{{item.content}}</text>
        </view>
        <view class="review-time">
          <text>{{item.createTime ? item.createTime.substring(0,10) : ''}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
