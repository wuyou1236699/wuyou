.container {
  min-height: 100vh;
  background: #FDF8F5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  display: block;
}

.category-scroll {
  white-space: nowrap;
  margin: -40rpx 20rpx 20rpx;
  padding: 10rpx;
}

.category-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 20rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.category-item {
  padding: 16rpx 32rpx;
  background: #FDF8F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8C7373;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  color: white;
}

.article-list {
  padding: 20rpx;
}

.article-card {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.article-cover {
  width: 100%;
  height: 280rpx;
}

.article-content {
  padding: 24rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2C;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.article-summary {
  font-size: 26rpx;
  color: #8C7373;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.article-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #B8A0A0;
}

.article-category {
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #B8A0A0;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8A0A0;
}
