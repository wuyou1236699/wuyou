.container {
  min-height: 100vh;
  background: #FDF8F5;
  padding-bottom: 120rpx;
}

.article-header {
  background: white;
}

.article-cover {
  width: 100%;
  height: 400rpx;
}

.article-info {
  padding: 30rpx;
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3D2C2C;
  display: block;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #B8A0A0;
}

.meta-item {
  padding: 6rpx 16rpx;
  background: #FDF8F5;
  border-radius: 10rpx;
}

.article-content {
  height: calc(100vh - 600rpx);
  padding: 30rpx;
}

.content-inner {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.content-inner :deep(p) {
  font-size: 28rpx;
  color: #3D2C2C;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.content-inner :deep(h2) {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2C;
  margin: 32rpx 0 16rpx;
}

.content-inner :deep(h3) {
  font-size: 28rpx;
  font-weight: bold;
  color: #3D2C2C;
  margin: 24rpx 0 12rpx;
}

.content-inner :deep(ul), .content-inner :deep(ol) {
  padding-left: 40rpx;
  margin-bottom: 24rpx;
}

.content-inner :deep(li) {
  font-size: 28rpx;
  color: #3D2C2C;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.content-inner :deep(strong) {
  font-weight: bold;
  color: #3D2C2C;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #B8A0A0;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.footer-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  border-radius: 16rpx;
}

.footer-icon {
  font-size: 36rpx;
}

.footer-text {
  font-size: 22rpx;
  color: white;
  margin-top: 4rpx;
}
