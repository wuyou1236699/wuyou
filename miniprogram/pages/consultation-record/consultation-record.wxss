page {
  background-color: #FDF8F5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.filter-tabs {
  display: flex;
  background: white;
  border-radius: 24rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #8C7373;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  color: white;
  font-weight: bold;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #FF7E67;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #8C7373;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.counselor-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.counselor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.counselor-details {
  display: flex;
  flex-direction: column;
}

.counselor-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #3D2C2C;
  margin-bottom: 8rpx;
}

.record-date {
  font-size: 24rpx;
  color: #B8A0A0;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.completed {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.draft {
  background: #fff3e0;
  color: #ff9800;
}

.card-body {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #B8A0A0;
  min-width: 120rpx;
}

.info-value {
  font-size: 26rpx;
  color: #3D2C2C;
  flex: 1;
}

.card-footer {
  background: #FFF5F2;
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestions-label {
  font-size: 26rpx;
  color: #B8A0A0;
  display: block;
  margin-bottom: 12rpx;
}

.suggestions-content {
  font-size: 26rpx;
  color: #3D2C2C;
  line-height: 40rpx;
  white-space: pre-wrap;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8A0A0;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
