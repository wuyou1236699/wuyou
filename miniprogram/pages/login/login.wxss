page {
  background: -webkit-linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 100rpx 50rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  background: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.10);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #3D2C2C;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 90rpx;
  background: #FFF5F2;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.btn-login {
  width: 100%;
  height: 100rpx;
  background: -webkit-linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,126,103,0.3);
}

.btn-register {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
}

.register-text {
  font-size: 26rpx;
  color: #B8A0A0;
}

.register-link {
  font-size: 26rpx;
  color: #FF7E67;
  margin-left: 10rpx;
  font-weight: 500;
}
