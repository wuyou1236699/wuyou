/* 全局样式 */
.container {
  background-color: #FDF8F5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 4rpx solid #FF7E67;
}

.avatar-edit-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 0 0 60rpx 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-tip text {
  font-size: 20rpx;
  color: #fff;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2C;
  margin-bottom: 8rpx;
  display: block;
}

.user-id {
  font-size: 24rpx;
  color: #8C7373;
  display: block;
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 30rpx;
}

.menu-group {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.menu-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #3D2C2C;
  padding: 20rpx 30rpx 10rpx;
  display: block;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:hover {
  background-color: #FFF5F2;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #3D2C2C;
}

.menu-arrow {
  font-size: 24rpx;
  color: #B8A0A0;
}

/* 退出登录按钮 */
.logout-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  font-size: 30rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s;
}

.logout-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.4);
}

/* 版本信息 */
.version {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #B8A0A0;
  margin-bottom: 30rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .container {
    padding: 16rpx;
  }
  
  .user-info-section {
    padding: 24rpx;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .nickname {
    font-size: 28rpx;
  }
  
  .menu-item {
    padding: 20rpx 24rpx;
  }
  
  .logout-btn {
    padding: 20rpx;
    font-size: 28rpx;
  }
}