/* 聊天页面样式 */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FDF8F5;
}

/* 顶部导航 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  color: #3D2C2C;
  width: 40rpx;
}

.chat-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3D2C2C;
  flex: 1;
  text-align: center;
}

.header-right {
  width: 40rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.user-message {
  flex-direction: row-reverse;
}

/* 头像 */
.message-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.message-avatar image {
  width: 100%;
  height: 100%;
}

/* 消息内容 */
.message-content {
  max-width: 75%;
  display: flex;
  flex-direction: column;
}

.user-message .message-content {
  align-items: flex-end;
}

/* 消息气泡 */
.message-bubble {
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  word-break: break-word;
}

.user-bubble {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  color: white;
  border-bottom-right-radius: 4rpx;
}

.ai-bubble {
  background: white;
  color: #3D2C2C;
  border-bottom-left-radius: 4rpx;
}

/* 消息文本 */
.message-text {
  font-size: 28rpx;
  line-height: 40rpx;
}

.user-bubble .message-text {
  color: white;
}

.ai-bubble .message-text {
  color: #3D2C2C;
}

/* 消息时间 */
.message-time {
  font-size: 20rpx;
  color: #B8A0A0;
  margin-top: 4rpx;
}

.user-message .message-time {
  text-align: right;
}

/* 输入区域 */
.input-bar {
  display: flex;
  align-items: center;
  background: white;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input-field {
  flex: 1;
  background: #FFF5F2;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
  min-height: 80rpx;
  max-height: 160rpx;
  overflow-y: auto;
}

.input-placeholder {
  color: #B8A0A0;
}

/* 发送按钮 */
.send-btn {
  background: linear-gradient(135deg, #FF7E67 0%, #E06952 100%);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  min-width: 120rpx;
  transition: all 0.3s;
}

.send-btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(255,126,103,0.3);
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .message-content {
    max-width: 70%;
  }
  
  .message-avatar {
    width: 50rpx;
    height: 50rpx;
    margin: 0 12rpx;
  }
  
  .message-bubble {
    padding: 14rpx 20rpx;
  }
  
  .message-text {
    font-size: 26rpx;
    line-height: 36rpx;
  }
  
  .input-field {
    padding: 14rpx 20rpx;
    font-size: 26rpx;
  }
  
  .send-btn {
    font-size: 24rpx;
    padding: 14rpx 28rpx;
  }
}

.load-more-tip {
  text-align: center;
  padding: 16rpx;
  color: #8C8CA1;
  font-size: 24rpx;
}