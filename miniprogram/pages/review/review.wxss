.container {
  padding: 40rpx;
  background-color: #FFF5F2;
  min-height: 100vh;
}
.rating-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}
.label {
  font-size: 32rpx;
  margin-right: 30rpx;
}
.stars {
  display: flex;
  align-items: center;
}
.star {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}
.content-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
}
.review-textarea {
  width: 100%;
  height: 300rpx;
  font-size: 30rpx;
  padding: 10rpx;
  box-sizing: border-box;
}
.counter {
  text-align: right;
  font-size: 24rpx;
  color: #B8A0A0;
  margin-top: 10rpx;
}
.submit-btn {
  background-color: #FF7E67;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 24rpx;
  margin-top: 60rpx;
}
.star {
  font-size: 48rpx;
  margin-right: 20rpx;
  display: inline-block;
}
.star-filled {
  color: #FFD700;
}
.star-empty {
  color: #ddd;
}